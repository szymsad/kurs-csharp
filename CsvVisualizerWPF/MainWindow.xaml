<Window x:Class="CsvVisualizerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CsvVisualizerWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" Grid.Column="0" 
        Content="Wczytaj CSV" 
        Command="{Binding WczytajCommand}"
        Margin="5"/>
        <TextBlock Grid.Row="0" Grid.Column="1" 
           Text="{Binding Status}" 
           VerticalAlignment="Center" Margin="10"/>
        <DataGrid Grid.Row="1" Grid.Column="0" 
          ItemsSource="{Binding Rekordy}"
          AutoGenerateColumns="True"
          IsReadOnly="True"
          Margin="5"/>
        <Border Grid.Row="1" Grid.Column="1" Background="LightGray" Margin="5"/>
    </Grid>
</Window>
