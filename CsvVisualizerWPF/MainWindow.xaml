<Window x:Class="CsvVisualizerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="CSV Visualizer" Height="600" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" Grid.Column="0" 
        Content="Wczytaj CSV" 
        Command="{Binding WczytajCommand}"
        Margin="5"/>
        <TextBlock Grid.Row="0" Grid.Column="1" 
           Text="{Binding Status}" 
           VerticalAlignment="Center" Margin="10"/>
        
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" 
            Orientation="Horizontal" 
            Margin="5">
            <TextBlock Text="Od:" VerticalAlignment="Center" Margin="5 0"/>
            <DatePicker SelectedDate="{Binding DataOd}" Width="120"/>
            <TextBlock Text="Do:" VerticalAlignment="Center" Margin="10 0 5 0"/>
            <DatePicker SelectedDate="{Binding DataDo}" Width="120"/>
            <Button Content="Kategorie / Produkty" 
            Command="{Binding PrzelaczCommand}"
            Margin="20 0 0 0" Padding="10 0"/>
        </StackPanel>

        <DataGrid Grid.Row="2" Grid.Column="0" 
          ItemsSource="{Binding Rekordy}"
          AutoGenerateColumns="True"
          IsReadOnly="True"
          Margin="5"/>
        <lvc:CartesianChart Grid.Row="2" Grid.Column="1"
                    Series="{Binding Series}"
                    XAxes="{Binding XAxes}"
                    Margin="5"/>
    </Grid>
</Window>
