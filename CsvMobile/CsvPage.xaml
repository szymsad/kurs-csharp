<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CsvMobile.CsvPage"
             Title="Analiza CSV">
    <VerticalStackLayout Padding="20" Spacing="10">

        <Button Text="Wczytaj CSV" 
                Clicked="WczytajPlik"/>

        <Label x:Name="statusLabel" 
               Text="Brak danych"/>

        <CollectionView x:Name="listaRekordow">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,*,*" Padding="5">
                        <Label Grid.Column="0" Text="{Binding Produkt}"/>
                        <Label Grid.Column="1" Text="{Binding Kategoria}"/>
                        <Label Grid.Column="2" Text="{Binding Cena}"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>